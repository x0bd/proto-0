{
	"name": "@xoboid/avatar",
	"version": "0.1.0",
	"description": "Animated SVG avatar component with multi-variant face system and audio reactivity",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		},
		"./avatar.css": "./avatar.css"
	},
	"files": [
		"dist",
		"avatar.css",
		"README.md",
		"dot-1 (1).png",
		"dot-1 (2).png",
		"dot-1 (3).png"
	],
	"scripts": {
		"build": "tsup",
		"build:watch": "tsup --watch",
		"type-check": "tsc --noEmit"
	},
	"peerDependencies": {
		"react": ">=18",
		"react-dom": ">=18",
		"gsap": ">=3.12"
	},
	"peerDependenciesMeta": {
		"react-dom": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.0",
		"tsup": "^8.0.0",
		"typescript": "^5.5.3"
	},
	"tsup": {
		"entry": [
			"src/index.ts"
		],
		"format": [
			"esm",
			"cjs"
		],
		"dts": true,
		"sourcemap": true,
		"external": [
			"react",
			"react-dom",
			"gsap"
		],
		"treeshake": true,
		"clean": true
	}
}
